@using POMQC.ViewModels.Base;
@using POMQC.Entities.Base;
@using Newtonsoft.Json;
 
@{
    Layout = null;
}
@{
    var imgs = Model.Item.Images;
    var groupCodes = Model.DefectCodes.Where(c => c.Active).GroupBy(c => c.CatName);
    var defectLocations = Model.DefectLocations.Where(c => c.Active);
    var count = 0;
    var index = 0;
    var passComment = Model.Item.FinalStatus == StatusType.Pass ?
        Model.Item.FinalComment : string.Empty;
    var rejectComment = Model.Item.FinalStatus == StatusType.Failed ?
        Model.Item.FinalComment : string.Empty;
    var onholdComment = Model.Item.FinalStatus == StatusType.OnHold ?
        Model.Item.FinalComment : string.Empty;
}
@model FinalViewModel
<div class="container tab-pane fade" id="@Model.Function">    
    <div class="content-main">
        <input type="hidden" id="finalid@((int)Model.Function)" value="@Model.Item.FinalId" />
        <div id="errmsg2@((int)Model.Function)" style="display: none"></div>
        <div class="dashboard-tbl">
        <table id="final@((int)Model.Function)">
            <thead>
                <tr>
                    <td>No.</td>
                    <td>Created Date</td>
                    <td>Created By</td>
                    <td>Updated Date</td>
                    <td>Updated By</td>
                </tr>
            </thead>
            <tbody style="cursor: pointer">
                @if (Model.Items.Count == 0)
                {
                <tr>
                    <td colspan="5" class="c">There is no information</td>
                </tr>    
                }
                @foreach (var item in Model.Items)
                {
                    ++count;
                <tr onclick="viewFinal(this, @item.CustId, '@item.CustPO', '@item.AIGLPO', '@item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff")', @((int)item.Type), @((int)Model.Function))" class="@(count == 1 ? "selected-row" : string.Empty)">
                    <td>@count</td>
                    <td>@item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff")</td>
                    <td>@item.CreatedUser</td>
                    <td>@item.UpdatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff")</td>
                    <td>@item.UpdatedUser</td>
                </tr>                    
                }
            </tbody>
        </table>
        </div>
        <br />
        <div style="font-weight: bold; padding: 3px" class="c form-header-title">@(Model.Function.ToString().ToUpperInvariant()) INSPECTION - PRODUCT QUALITY</div>
        <table>
            <tr>                    
                <td style="width: 20%" class="b r">Workmanship AQL</td>
                <td style="width: 20%"><input onchange="changeAQL(this, 1, 2, 3, @((int)Model.Function))" type="radio" @(Model.Item.WorkmanshipAQL == AQL.AQL10 ? "checked" : "") name="aql@((int)Model.Function)" id="aql10-@((int)Model.Function)" />1.0</td>
                <td style="width: 15%"><input onchange="changeAQL(this, 2, 1, 3, @((int)Model.Function))" type="radio" @(Model.Item.WorkmanshipAQL == AQL.AQL15 ? "checked" : "") name="aql@((int)Model.Function)" id="aql15-@((int)Model.Function)" />1.5</td>
                <td><input onchange="changeAQL(this, 3, 2, 1, @((int)Model.Function))" type="radio" @(Model.Item.WorkmanshipAQL == AQL.AQL25 ? "checked" : "") name="aql@((int)Model.Function)" id="aql25-@((int)Model.Function)" />2.5</td>
            </tr>
            <tr>
                <td class="b r">Measurement AQL</td>
                <td><input onchange="changeAQL2(this, 3, 1, 2, @((int)Model.Function))" type="radio" @(Model.Item.MeasurementAQL == AQL.AQL252 ? "checked" : "") name="aql2@((int)Model.Function)" id="aql252-@((int)Model.Function)" />2.5</td>
                <td><input onchange="changeAQL2(this, 1, 2, 3, @((int)Model.Function))" type="radio" @(Model.Item.MeasurementAQL == AQL.AQL40 ? "checked" : "") name="aql2@((int)Model.Function)" id="aql40-@((int)Model.Function)" />4.0</td>
                <td><input onchange="changeAQL2(this, 2, 3, 1, @((int)Model.Function))" type="radio" @(Model.Item.MeasurementAQL == AQL.AQL65 ? "checked" : "") name="aql2@((int)Model.Function)" id="aql65-@((int)Model.Function)" />6.5</td>
            </tr>
            <tr>                    
                <td class="b r">DATE</td>
                <td id="date@((int)Model.Function)">@(Model.Item.FinalId == 0 ? DateTime.Now.ToString("MM/dd/yyyy HH:mm:ss.fff") : Model.Item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.tt.fff"))</td>
                <td><input onchange="changeFinalStatus(this, 'pass-comment@((int)Model.Function)', 'on-hold-comment@((int)Model.Function)', 'reject-comment@((int)Model.Function)')" type="radio" @(Model.Item.FinalStatus == StatusType.Pass ? "checked" : "") name="final@((int)Model.Function)" id="pass@((int)Model.Function)" />PASS</td>
                <td><input @(Model.Item.FinalStatus != StatusType.Pass ? "disabled" : "") type="text" style="width: 95%" name="comment@((int)Model.Function)" class="pass" value="@passComment" id="pass-comment@((int)Model.Function)" /></td>
            </tr>
            <tr>
                <td class="b r">Audited by</td>
                <td><input type="text" style="width: 95%" id="audited-by@((int)Model.Function)" value="@Model.Item.AuditedBy" /></td>
                <td><input onchange="changeFinalStatus(this, 'reject-comment@((int)Model.Function)', 'on-hold-comment@((int)Model.Function)', 'pass-comment@((int)Model.Function)')" type="radio" @(Model.Item.FinalStatus == StatusType.Failed ? "checked" : "") name="final@((int)Model.Function)" id="reject@((int)Model.Function)" />REJECT</td>
                <td><input @(Model.Item.FinalStatus != StatusType.Failed ? "disabled" : "") type="text" style="width: 95%" name="comment@((int)Model.Function)" class="reject" value="@rejectComment" id="reject-comment@((int)Model.Function)" /></td>
            </tr>
            <tr>
                <td class="b r">Customer Name</td>
                <td id="custName2@((int)Model.Function)">@Model.Item.CustName</td>
                <td><input onchange="changeFinalStatus(this, 'on-hold-comment@((int)Model.Function)', 'pass-comment@((int)Model.Function)', 'reject-comment@((int)Model.Function)')" type="radio" @(Model.Item.FinalStatus == StatusType.OnHold ? "checked" : "") name="final@((int)Model.Function)" id="on-hold@((int)Model.Function)" />ON HOLD</td>
                <td><input @(Model.Item.FinalStatus != StatusType.OnHold ? "disabled" : "") type="text" style="width: 95%" name="comment@((int)Model.Function)" class="on-hold" value="@onholdComment" id="on-hold-comment@((int)Model.Function)" /></td>
            </tr>
            <tr>
                <td class="b r">Factory Name</td>
                <td id="factName2@((int)Model.Function)">@Model.Item.FactoryName</td>
                <td class="b">Main Label</td>
                <td><input type="text" style="width: 95%" id="main-label@((int)Model.Function)" value="@Model.Item.MainLabel" /></td>
            </tr>
            <tr>
                <td class="b r">Factory Manager</td>
                <td><input type="text" style="width: 95%" id="factory-manager@((int)Model.Function)" value="@Model.Item.FactoryManager" /></td>
                <td class="b">Qty Inspected</td>
                <td><span style="width: 95%" id="qty-inspected@((int)Model.Function)">@Model.POs.Sum(p => p.InspectedQty)</span></td>
            </tr>
            <tr>
                <td class="b r">Actual Inspection Date</td>
                <td>@Html.Partial("_DatePicker2", new POMQC.ViewModels.Base.DatePickerViewModel { Date = Model.DateRange.From.Date })</td>
                <td class="b">Actual Product Qty</td>
                <td><span style="width: 95%" id="act-product-qty@((int)Model.Function)">@Model.POs.Sum(p => p.ActualProductQty)</span></td>
            </tr>
        </table>
