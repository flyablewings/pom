        <div style="clear: both"></div>
        <br />
        <table id="po-list@((int)Model.Function)">
            <thead>
                <tr class="b c">
                    <td>AIGL PO</td>
                    <td>Customer PO</td>
                    <td>Style</td>
                    <td>Color or Code</td>
                    <td>Order Qty/color</td>
                    <td>Inspected Qty</td>
                    <td>Actual Product Qty</td>
                </tr>
            </thead>
            <tbody>
                @if (!Model.POs.Any())
                {
                <tr>
                    <td colspan="7" class="c">There is no information</td>
                </tr>    
                }
                else
                {
                    var id = 0;
                    foreach (var po in Model.POs)
                    {                        
                <tr>                    
                    <td>@po.AIGLPO<input type="hidden" id="fdid-@((int)Model.Function)-@id" value="@po.FinalDetailId" /></td>
                    <td>@po.CustPO</td>
                    <td id="style-@((int)Model.Function)-@id">@po.Style</td>
                    <td id="color-@((int)Model.Function)-@id">@po.Color</td>
                    <td class="r" id="qty-@((int)Model.Function)-@id">@po.OrderQuantity</td>
                    <td class="r"><input id="ins-@((int)Model.Function)-@id" value="@po.InspectedQty" /></td>
                    <td class="r"><input id="act-@((int)Model.Function)-@id" value="@po.ActualProductQty" /></td>
                </tr>    
                        ++id;
                    }
                }
            </tbody>
            <tfoot>
                <tr class="b r">
                    <td colspan="4">TOTAL</td>
                    <td id="sum-po-list@((int)Model.Function)">@(Model.POs.Any() ? Model.POs.Sum(p => p.OrderQuantity).ToString("#,###") : "0")</td>
                    <td id="sum-ins-list@((int)Model.Function)">@(Model.POs.Any() ? Model.POs.Sum(p => p.InspectedQty).ToString("#,###") : "0")</td>
                    <td id="sum-act-list@((int)Model.Function)">@(Model.POs.Any() ? Model.POs.Sum(p => p.ActualProductQty).ToString("#,###") : "0")</td>
                </tr>
            </tfoot>
        </table>        
        <br />
