            </tr>
        </table>
        <br />
        <div class="content-nested">
            <div class="b">COMMENTS</div>
            <div>
                <textarea rows="2" style="width: 100%" id="final-comment@((int)Model.Function)">@Model.Item.Comment</textarea>
            </div>
        </div>
        <br />
        <table id="tbl-final@((int)Model.Function)">
            <thead>
                <tr class="b c">
                    <td style="width: 30%">DEFECT DESCRIPTION</td>
                    <td style="width: 30%">DEFECT LOCATION</td>
                    <td style="width: 20%">MAJOR</td>
                    <td>MINOR</td>
                </tr>
            </thead>
            <tbody>
                @if (Model.Defects.Any())
                {
                    foreach (var defect in Model.Defects)
                    {
                <tr>
                    <td>
                        <input type="hidden" name="ddefid@((int)Model.Function)" value="@defect.DdefId" />
                        <select name="codes@((int)Model.Function)" style="width: 95%" onchange="changeDefectFinal(this, @((int)Model.Function), @index);">
                            @foreach (var group in groupCodes)
                            {
                            <optgroup label="@group.First().CatName">
                                @foreach (var item in group)
                                {
                                    var selectedCode = defect.DefId == item.DefId ? "selected" : string.Empty;
                                <option major="@((int)item.Type)" @selectedCode value="@item.DefId">@(string.IsNullOrWhiteSpace(item.DefCode) ? "- " + item.DefName : item.DefCode + " - " + item.DefName + (string.IsNullOrWhiteSpace(item.DefVN) ? " -" : " - " + item.DefVN))</option>    
                                }                                
                            </optgroup>                                    
                            }
                        </select>
                    </td>
                    <td>
                        <select name="locations@((int)Model.Function)" style="width: 95%">
                            @foreach (var item in defectLocations)
                            {
                                var selectedLoc = defect.LocId == item.LocId ? "selected" : string.Empty;
                            <option @selectedLoc value="@item.LocId">@item.LocName</option>    
                            }
                        </select>
                    </td>
                    <td id="def-0@(index)@((int)Model.Function)">@Html.Raw(defect.Type == DefectType.Major ? "<input type='text' style='width: 95%' class='r' name='defect" + ((int)Model.Function) + "' value='" + defect.Total + "' />" : string.Empty)</td>
                    <td id="def-1@(index)@((int)Model.Function)">@Html.Raw(defect.Type == DefectType.Minor ? "<input type='text' style='width: 95%' class='r' name='defect" + ((int)Model.Function) + "' value='" + defect.Total + "' />" : string.Empty)</td>
                </tr>
                            ++index;
                    }
                }
                <tr>
                    <td>
                        <input type="hidden" name="ddefid@((int)Model.Function)" value="0" />
                        <select name="codes@((int)Model.Function)" style="width: 95%" onchange="changeDefectFinal(this, @((int)Model.Function), @index);">
                            @foreach (var group in groupCodes)
                            {
                            <optgroup label="@group.First().CatName">
                                @foreach (var item in group)
                                {
                                <option major="@((int)item.Type)" value="@item.DefId">@(string.IsNullOrWhiteSpace(item.DefCode) ? "- " + item.DefName : item.DefCode + " - " + item.DefName)</option>    
                                }                                
                            </optgroup>                                    
                            }
                        </select>
                    </td>
                    <td>
                        <select name="locations@((int)Model.Function)" style="width: 95%">
                            @foreach (var item in defectLocations)
                            {
                            <option value="@item.LocId">@item.LocName</option>    
                            }
                        </select>
                    </td>
                    <td id="def-0@(index)@((int)Model.Function)"></td>
                    <td id="def-1@(index)@((int)Model.Function)"></td>
                </tr>                
            </tbody>
            <tfoot>
                <tr class="b r">
                    <td colspan="2">TOTAL</td>
                    <td id="total-defect@((int)Model.Function)">@(Model.Defects.Any() ? Model.Defects.Where(d => d.Type == DefectType.Major).Sum(d => d.Total) : 0)</td>
                    <td id="total-defect2@((int)Model.Function)">@(Model.Defects.Any() ? Model.Defects.Where(d => d.Type == DefectType.Minor).Sum(d => d.Total) : 0)</td>
                </tr>
            </tfoot>
        </table>
        <br />
        <div class="content-main">
            <div class="b">SPEC MEASUREMENT & PACKING INTEGRITY AUDIT</div>
            @if (Model.IsReadOnly)
            {
            <div class="swiper-container2@((int)Model.Function)" style="border-bottom: none; height: 292px">
                <div class="swiper-wrapper" id="img2@((int)Model.Function)">
                    @foreach (var item in Model.Item.Images)
                    {
                        if (item.hasImage)
                        {
                    <a class="swiper-slide" data-lightbox="img2@((int)Model.Function)" href="@Url.Content("~/Images/Uploads/" + item.name)" style="background:url(@Url.Content("~/Images/Uploads/" + item.name))"></a>        
                        }
                    }    
                </div>
                <div class="swiper-button-next2@((int)Model.Function)"></div>
                <div class="swiper-button-prev2@((int)Model.Function)"></div>
            </div>
            }
            else
            {            
            <div style="max-height: 244px; overflow: auto">
                <form style="border: 1px solid #ccc; height:auto" action="@Url.Content("~/final/upload")" method="post" enctype="multipart/form-data" class="dropzone" id="dropzoneForm2@((int)Model.Function)">
                    <div class="fallback">
                        <input name="img2@((int)Model.Function)" type="file" multiple />            
                    </div>    
                </form>   
            </div>
            }
        </div>
        <br />
        <div class="content-nested">
            <div class="b">QA's COMMENTS</div>
            <div>
                <textarea rows="2" style="width: 100%" id="qa-comment@((int)Model.Function)">@Model.Item.QAComment</textarea>
            </div>
        </div>
        <br />
        <div class="content-nested">
            <div class="b">FACTORY CAPTION</div>
            <div>
                <textarea rows="2" style="width: 100%" id="factory-caption@((int)Model.Function)">@Model.Item.FactoryCaption</textarea>
            </div>
        </div>
        <br />
        <span class="b">QA AUDITOR:</span><input type="text" id="qa-auditor@((int)Model.Function)" value="@Model.Item.QAAuditor" />
        <span class="b">FACTORY REP:</span><input type="text" id="factory-rep@((int)Model.Function)" value="@Model.Item.FactoryRep" />
        <span class="b">AIGL QA MANAGER:</span><input type="text" id="qa-manager@((int)Model.Function)" value="@Model.Item.QAManager" />
    </div>
    @if (!Model.IsReadOnly)
    {
    <a href="javascript:;" class="btn btn-primary" role="button" id="submit2@((int)Model.Function)">Save</a>
    <script type="text/javascript">
        //File Upload response from the server
        Dropzone.options.dropzoneForm2@((int)Model.Function) = {
            autoProcessQueue: false,
            uploadMultiple: true,
            parallelUploads: 100,
            maxFiles: 100,
            acceptedFiles: AcceptedImageTypes,
            maxFilesize: 500,

            init: function () {
                this.on("success", function (data) {
                    if (data.xhr.status == 500) {
                        showMessage(2@((int)Model.Function), 'An error occurs, please check network connection, file types or try again later.', true);
                    }
                    else{
                        var result = JSON.parse(data.xhr.responseText);
                        showMessage(2@((int)Model.Function), result.Message, !result.IsSuccess);
                    }

                    unblockUI();
                });

                this.on("error", function (data) {
                    showMessage(2@((int)Model.Function), 'An error occurs, please check network connection, file types or try again later.', true);
                    unblockUI();
                });

                var submitButton = document.querySelector("#submit2@((int)Model.Function)");
                var wrapperThis = this;
                var custId = 0;
                var custPO = '';
                var aiglPO = '';

                submitButton.addEventListener("click", function () {
                    var aql = $('input[name="aql@((int)Model.Function)"]');
                    var aql2 = $('input[name="aql2@((int)Model.Function)"]');
                    var selectedAQL = false;
                    var selectedAQL2 = false;

                    var final = $('input[name="final@((int)Model.Function)"]');
                    var selectedFinalStatus = false;

                    var sumInspect = $('input[name="sum-inspect@((int)Model.Function)"]');
                    var sumInspect2 = $('input[name="sum-inspect2@((int)Model.Function)"]');
                    var sumInspect3 = $('input[name="sum-inspect3@((int)Model.Function)"]');
                    var selectedInspect = false;
                    var selectedInspect2 = false;
                    var selectedInspect3 = false;
                    var qtyInspected = $('#qty-inspected@((int)Model.Function)').val().trim();
                    var actProductQty = $('#act-product-qty@((int)Model.Function)').val().trim();

                    var codes = getDefectCodes(@((int)Model.Function));
                    var locations = getDefectLocations(@((int)Model.Function));

                    var tr = $('.selected-row');

                    if (tr && tr[0] && tr[0].cells) {
                        var custName = tr[0].cells[2].innerText;
                        var options = model.Customers;
                        for (var i = 0; i < options.length; i++) {
                            if (options[i].CustName == custName) {
                                custId = options[i].CustId;
                                break;
                            }
                        }

                        custPO = tr[0].cells[1].innerText;
                        aiglPO = tr[0].cells[0].innerText;
                    }

                    custId = custId != '0' ? custId : $("#ddlCUST").val();
                    custPO = custPO != '0' ? custPO : $("#ddlCUSTPO").val();
                    aiglPO = aiglPO != '0' ? aiglPO : $("#ddlAIGLPO").val();

                    for (var i = 0; i < aql.length; i++) {
                        if ($(aql[i]).is(':checked')) {
                            selectedAQL = true;
                            break;
                        }
                    }
                    for (var i = 0; i < aql2.length; i++) {
                        if ($(aql2[i]).is(':checked')) {
                            selectedAQL2 = true;
                            break;
                        }
                    }

                    for (var i = 0; i < final.length; i++) {
                        if ($(final[i]).is(':checked')) {
                            selectedFinalStatus = true;
                            break;
                        }
                    }

                    for (var i = 0; i < sumInspect.length; i++) {
                        if ($(sumInspect[i]).is(':checked')) {
                            selectedInspect = true;
                            break;
                        }
                    }
                    for (var i = 0; i < sumInspect2.length; i++) {
                        if ($(sumInspect2[i]).is(':checked')) {
                            selectedInspect2 = true;
                            break;
                        }
                    }
                    for (var i = 0; i < sumInspect3.length; i++) {
                        if ($(sumInspect3[i]).is(':checked')) {
                            selectedInspect3 = true;
                            break;
                        }
                    }

                    if ($("#finalid@((int)Model.Function)").val() == '0' && (custId == '0' || custPO == '0' || aiglPO == '0')) {
                        showMessage(2@((int)Model.Function), 'Please select Customer, Customer PO and AIGL PO.', true);
                    }
                    else if (!selectedAQL) {
                        showMessage(2@((int)Model.Function), 'Please select Workmanship AQL.', true);
                    }
                    else if (!selectedAQL2) {
                        showMessage(2@((int)Model.Function), 'Please select Measurement AQL.', true);
                    }
                    else if (!selectedFinalStatus){
                        showMessage(2@((int)Model.Function), 'Please select Final Status: PASS / REJECT / ON HOLD.', true);
                    }
                    else if (!selectedInspect){
                        showMessage(2@((int)Model.Function), 'Please select Visual/Workmanship Status: PASS / FAILED.', true);
                    }
                    else if (!selectedInspect2){
                        showMessage(2@((int)Model.Function), 'Please select Spec Measurement Status: PASS / FAILED.', true);
                    }
                    else if (!selectedInspect3){
                        showMessage(2@((int)Model.Function), 'Please select Packaging & Packing Integrity Status: PASS / FAILED.', true);
                    }
                    else if (codes.split(',').length != locations.split(',').length || 
                        codes.split(',').length == 0 || locations.split(',').length == 0 ||
                        (codes.split(',') != '' && locations.split(',') == '') ||
                        (codes.split(',') == '' && locations.split(',') != '')) {
                        showMessage(2@((int)Model.Function), 'Please select defect and location.', true);
                    }
                    else if (wrapperThis.getQueuedFiles().length > 0) {
                        wrapperThis.processQueue();
                    }
                    else {
                        // Upload anyway without files
                        wrapperThis.uploadFiles([{name:'nofiles'}]);
                    }
                });

                this.on("addedfile", function (file) {

                    // Create the remove button
                    var removeButton = Dropzone.createElement("<button class='btn btn-xs btn-warning' style='width: 120px; cursor: pointer'>Delete</button>");

                    // Listen to the click event
                    removeButton.addEventListener("click", function (e) {
                        // Make sure the button click doesn't submit the form:
                        e.preventDefault();
                        e.stopPropagation();

                        // If you want to the delete the file on the server as well,
                        // you can do the AJAX request here.
                        if (confirm('File will be deleted on server, cannot rollback, are you sure?')) {                    
                            $.ajax({
                                url: resolveClientUrl('final/delete'),
                                type: 'post',
                                data: {
                                    finalid: $("#finalid@((int)Model.Function)").val(),                                
                                    img: file.name
                                },
                                dataType: 'application/json'
                            }).complete(function (result) {      
                                var res = $.parseJSON(result.responseText);
                                if(res && !res.IsSuccess){
                                    alert(res.Message);
                                }
                                else {
                                    // Remove the file preview.
                                    wrapperThis.removeFile(file);
                                }
                            });
                        }
                    });

                    // Add the button to the file preview element.
                    file.previewElement.appendChild(removeButton);
                });

                // Send all form and input data below to server
                this.on('sendingmultiple', function (data, xhr, formData) {
                    blockUI();

                    var codes = getDefectCodes(@((int)Model.Function));
                    var locations = getDefectLocations(@((int)Model.Function));
                    var ids = getDefectIds(@((int)Model.Function));

                    var inspect = $('input[name="sum-inspect@((int)Model.Function)"]');
                    var inspect2 = $('input[name="sum-inspect2@((int)Model.Function)"]');
                    var inspect3 = $('input[name="sum-inspect3@((int)Model.Function)"]');
                    var inspectStatus = $(inspect[0]).is(':checked') ? 1 : 2;
                    var inspectStatus2 = $(inspect2[0]).is(':checked') ? 1 : 2;
                    var inspectStatus3 = $(inspect3[0]).is(':checked') ? 1 : 2;

                    var final = $('input[name="final@((int)Model.Function)"]');
                    var finalC = $('input[name="comment@((int)Model.Function)"]');
                    var finalStatus = $(final[0]).is(':checked') ? 1 : $(final[1]).is(':checked') ? 2 : 3;
                    var finalComment = $(final[0]).is(':checked') ? $(finalC[0]).val() : $(final[1]).is(':checked') ? $(finalC[1]).val() : $(finalC[2]).val();
                    
                    var aql = $('input[name="aql@((int)Model.Function)"]');
                    var aql2 = $('input[name="aql2@((int)Model.Function)"]');
                    var wAQL = $(aql[0]).is(':checked') ? 1 : $(aql[1]).is(':checked') ? 2 : 3;
                    var mAQL = $(aql2[0]).is(':checked') ? 6 : $(aql2[1]).is(':checked') ? 4 : 5;
                    var totalDefects = getDefectTotal(@((int)Model.Function));
                    
                    formData.append("CustId", custId);
                    formData.append("CustPO", custPO);
                    formData.append("AIGLPO", aiglPO);
                    formData.append("Comment", $("#final-comment@((int)Model.Function)").val() || 'N/A');
                    formData.append("Type", @((int)Model.Function));
                    formData.append("AuditedBy", $("#audited-by@((int)Model.Function)").val() || 'N/A');
                    formData.append("MainLabel", $("#main-label@((int)Model.Function)").val() || 'N/A');
                    formData.append("FactoryManager", $("#factory-manager@((int)Model.Function)").val() || 'N/A');
                    formData.append("QtyInspected", $("#qty-inspected@((int)Model.Function)").val() || 'N/A');
                    formData.append("CartonComment", $("#carton-comment@((int)Model.Function)").val() || 'N/A');
                    formData.append("WorkmanshipStatus", inspectStatus);
                    formData.append("WorkmanshipComment", $("#sum-comment@((int)Model.Function)").val() || 'N/A');
                    formData.append("MeasurementStatus", inspectStatus2);
                    formData.append("MeasurementComment", $("#sum-comment2@((int)Model.Function)").val() || 'N/A');
                    formData.append("PackingStatus", inspectStatus3);
                    formData.append("PackingComment", $("#sum-comment3@((int)Model.Function)").val() || 'N/A');
                    formData.append("FinalStatus", finalStatus);
                    formData.append("FinalComment", finalComment || 'N/A');
                    formData.append("QAComment", $("#qa-comment@((int)Model.Function)").val() || 'N/A');
                    formData.append("FactoryCaption", $("#factory-caption@((int)Model.Function)").val() || 'N/A');
                    formData.append("QAAuditor", $("#qa-auditor@((int)Model.Function)").val() || 'N/A');
                    formData.append("FactoryRep", $("#factory-rep@((int)Model.Function)").val() || 'N/A');
                    formData.append("QAManager", $("#qa-manager@((int)Model.Function)").val() || 'N/A');
                    formData.append("WorkmanshipAQL", wAQL);
                    formData.append("MeasurementAQL", mAQL);                  
                    
                    formData.append("DefectCodes", codes || " ");
                    formData.append("DefectLocs", locations || " ");
                    formData.append("TotalDefects", totalDefects || " ");
                    formData.append("CreatedDate", $('#date@((int)Model.Function)').html());
                    formData.append("DefectIds", ids || " ");
                    formData.append("FinalId", $("#finalid@((int)Model.Function)").val());

                    var idx = @((int)Model.Function) == DHU.Prefinal ? 0 : 1;
                    formData.append("ActualInspectionDate", $('.datepicker2')[idx].value);
                    formData.append("ActualProductQuantity", $("#act-product-qty@((int)Model.Function)").val());

                    formData.append("EntitiesString", JSON.stringify(getFinalPOs(@((int)Model.Function))));
                });
            }
        };

        var mockFiles@((int)Model.Function) = @Html.Raw(JsonConvert.SerializeObject(imgs));
        $(document).ready(function(){
            setTimeout(function(){
                var aql = $('input[name="aql@((int)Model.Function)"]');
                var aql2 = $('input[name="aql2@((int)Model.Function)"]');

                if (@((int)Model.Item.WorkmanshipAQL) == 1) {
                    $(aql[0]).prop('checked', true);
                    changeAQL(aql[0], 1, 2, 3, @((int)Model.Function));
                }
                else if (@((int)Model.Item.WorkmanshipAQL) == 2) {
                    $(aql[1]).prop('checked', true);
                    changeAQL(aql[1], 2, 1, 3, @((int)Model.Function));
                }
                else if (@((int)Model.Item.WorkmanshipAQL) == 3) {
                    $(aql[2]).prop('checked', true);
                    changeAQL(aql[2], 3, 2, 1, @((int)Model.Function));
                }

                if (@((int)Model.Item.MeasurementAQL) == 4) {
                    $(aql2[0]).prop('checked', true);
                    changeAQL2(aql2[0], 1, 2, @((int)Model.Function));
                }
                else if (@((int)Model.Item.MeasurementAQL) == 5) {
                    $(aql2[1]).prop('checked', true);
                    changeAQL2(aql2[1], 2, 1, @((int)Model.Function));
                }
            }, 3000);
        });
    </script>
    }
    <a href="javascript:window.print();" class="btn btn-primary" role="button">Print</a>    
    <a id="export-final@((int)Model.Function)" href="@Url.Content("~/final/export?custId=" + Model.Item.CustId + "&custPO=" + Model.Item.CustPO + "&aiglPO=" + Model.Item.AIGLPO + "&date=" + Model.Item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff") + "&type=" + ((int)Model.Function))" target="_blank" class="btn btn-primary" role="button">Export Excel</a>
    <a id="export-final2@((int)Model.Function)" href="@Url.Content("~/final/exportpdf?custId=" + Model.Item.CustId + "&custPO=" + Model.Item.CustPO + "&aiglPO=" + Model.Item.AIGLPO + "&date=" + Model.Item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff") + "&type=" + ((int)Model.Function))" target="_blank" class="btn btn-primary" role="button">Export PDF</a>
    <a href="mailto:" class="btn btn-primary" role="button">Open Mail</a>
    <a id="export-final3@((int)Model.Function)" href="javascript:sendMail(false, @Model.Item.CustId, '@Model.Item.CustPO', '@Model.Item.AIGLPO', '@Model.Item.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss.fff")', @((int)Model.Function));" class="btn btn-primary" role="button">Send Mail</a>
</div>