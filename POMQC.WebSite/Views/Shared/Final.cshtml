                    <input type="radio" name="sum-inspect3@((int)Model.Function)" @(Model.Item.PackingStatus == StatusType.Pass ? "checked" : string.Empty) /></td>
                <td>
                    <input type="radio" name="sum-inspect3@((int)Model.Function)" @(Model.Item.PackingStatus == StatusType.Failed ? "checked" : string.Empty) /></td>
                <td>
