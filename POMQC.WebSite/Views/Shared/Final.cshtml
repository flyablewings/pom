                    <input type="radio" name="sum-inspect@((int)Model.Function)" @(Model.Item.WorkmanshipStatus == StatusType.Pass ? "checked" : string.Empty) /></td>
                <td>
                    <input type="radio" name="sum-inspect@((int)Model.Function)" @(Model.Item.WorkmanshipStatus == StatusType.Failed ? "checked" : string.Empty) /></td>
                <td>
                    <input type="text" style="width: 95%" id="sum-comment@((int)Model.Function)" value="@Model.Item.WorkmanshipComment" /></td>
            </tr>
            <tr class="c">-
                <td class="b">
                    Spec measurement</td>
                <td>
                    <input type="radio" name="sum-inspect2@((int)Model.Function)" @(Model.Item.MeasurementStatus == StatusType.Pass ? "checked" : string.Empty) /></td>
                <td>
                    <input type="radio" name="sum-inspect2@((int)Model.Function)" @(Model.Item.MeasurementStatus == StatusType.Failed ? "checked" : string.Empty) /></td>
                <td>
                    <input type="text" style="width: 95%" id="sum-comment2@((int)Model.Function)" value="@Model.Item.MeasurementComment" /></td>
            </tr>
            <tr class="c">
