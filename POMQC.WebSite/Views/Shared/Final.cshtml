            <div>
                <textarea rows="2" style="width: 100%" id="carton-comment@((int)Model.Function)">@Model.Item.CartonComment</textarea>
            </div>
        </div>
        <br />
        <table>
            <thead>
                <tr class="c">
                    <td colspan="4" class="b">
                        INSPECTION SUMMARY</td>
                </tr>                
            </thead>    
            <tr class="c">
                <td class="b">
                    INSPECTION PROPERTY</td>
                <td class="b">
                    PASSED</td>
                <td class="b">
                    FAILED</td>
                <td class="b">
                    COMMENTS</td>
            </tr>                
