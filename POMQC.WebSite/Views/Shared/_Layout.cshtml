@{
    var dashboardClass = string.Empty;
    var sampleClass = string.Empty;
    var qualityClass = string.Empty;
    var meetingClass = string.Empty;
    var inspectionClass = string.Empty;
    var reportClass = string.Empty;
    var defectClass = string.Empty;

    switch (Context.Request.Url.AbsolutePath.ToLowerInvariant())
    {
        case "/":
            dashboardClass = "active";
            break;
        case "/home/sample":
            sampleClass = "active";
            break;
        case "/home/quality":
            qualityClass = "active";
            break;
        case "/home/meeting":
            meetingClass = "active";
            break;
        case "/home/report":
            reportClass = "active";
            break;
        case "/home/defect":
            defectClass = "active";
            break;
        default:
            inspectionClass = "active";
            break;
    }
}
