@using System.Linq;
@using POMQC.ViewModels.Checklist;
@using POMQC.ViewModels.Filter;

@model ChecklistViewModel
@{
    ViewBag.Title = "Sample";
    
    var fitSample = Model.Items.FirstOrDefault(i => i.Function == ChecklistFunctionViewModel.FitSample) ?? new ChecklistViewModel();
    fitSample.Function = ChecklistFunctionViewModel.FitSample;
    fitSample.IsActiveTab = true;
    fitSample.Title = "FIT SAMPLE APPROVED";
    
    var ppSample = Model.Items.FirstOrDefault(i => i.Function == ChecklistFunctionViewModel.PPSample) ?? new ChecklistViewModel();
    ppSample.Function = ChecklistFunctionViewModel.PPSample;
    ppSample.Title = "PP SAMPLE APPROVED";
    
    var topSample = Model.Items.FirstOrDefault(i => i.Function == ChecklistFunctionViewModel.TopSample) ?? new ChecklistViewModel();
    topSample.Function = ChecklistFunctionViewModel.TopSample;
    topSample.Title = "TOP SAMPLE APPROVED";

    var count = 0;
}
@Html.Partial("Filter", Model.Filter)
<div class="dashboard-tbl">
    <table id="main">
        <thead>
            <tr>
                <td>AIGL PO</td>
                <td>Cust PO</td>
                <td>Cust Name</td>
                <td>Factory</td>
                <td>Related Divison</td>
                <td>Inline Date</td>
                <td>Status</td>
                <td>PO Qty</td>
                <td>Total Defects</td>
            </tr>
        </thead>
        <tbody>
            @if (Model.POs.Any())
            {
                foreach (var item in Model.POs)
                {
            <tr class="@(count == 0 ? "selected-row" : string.Empty)" onclick="sampleDetail(this, @item.CustId, '@item.CustPO', '@item.AIGLPO', '@item.Customer', @item.FactoryId)">
                <td>@item.AIGLPO</td>
                <td>@item.CustPO</td>
                <td>@item.Customer</td>
                <td>@item.Factory</td>
                <td>@item.Division</td>
                <td>@item.InlineDate</td>
                <td>@item.Status</td>
                <td class="r">@item.POQty</td>
                <td class="r">@item.Defect</td>
            </tr>
                    ++count;
                }
            }
            else
            {
            <tr>
                <td colspan="9" class="c">There is no information</td>
            </tr>
            }
        </tbody>
    </table>
</div>
<ul class="nav nav-tabs" role="tablist">
  <li role="presentation" class="active"><a role="tab" data-toggle="tab" aria-expanded="true" href="#FitSample">FIT SAMPLE</a></li>
  <li role="presentation"><a role="tab" data-toggle="tab" aria-expanded="false" href="#PPSample">PP SAMPLE</a></li>
  <li role="presentation"><a role="tab" data-toggle="tab" aria-expanded="false" href="#TopSample">TOP SAMPLE</a></li>
</ul>
<div class="tab-content">    
    @Html.Partial("Checklist", fitSample)
    @Html.Partial("Checklist", ppSample)
    @Html.Partial("Checklist", topSample)
</div>